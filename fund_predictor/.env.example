# ====================================================
# 基金预测系统环境变量配置（v2.6.0）
# ====================================================
# 复制此文件为 .env 并填写实际值
# 注意：.env 文件已加入 .gitignore，请勿提交至版本控制

# ====================================================
# ★ AI Provider API Keys（v2.6.0 新增）
# ====================================================

# 智谱 GLM API Key（主 Provider）
# 获取地址: https://open.bigmodel.cn/usercenter/apikeys
GLM_API_KEY=your_glm_api_key_here

# 硅基流动 API Key（备用 Provider）
# 获取地址: https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# ====================================================
# 数据库配置（可选，默认使用 SQLite）
# ====================================================
# DATABASE_URL=sqlite:///./output/app.db

# ====================================================
# 日志级别（可选）
# ====================================================
# LOG_LEVEL=INFO
